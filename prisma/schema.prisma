// Schéma de base de données IPT Business
// Base : TiDB Cloud Serverless (compatible MySQL)
// relationMode = "prisma" : TiDB Serverless ne supporte pas les FK natives,
// Prisma gère donc l'intégrité référentielle côté application.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ---------- ENUMS ----------

enum Plan {
  GRATUIT
  PREMIUM
}

enum StatutFacture {
  PAYEE
  IMPAYEE
  ANNULEE
}

enum StatutPaiement {
  EN_ATTENTE
  VALIDE
  REJETE
}

enum StatutCommande {
  NOUVELLE
  CONFIRMEE
  LIVREE
  ANNULEE
}

enum CategorieActivite {
  COMMERCANT
  ARTISAN
  FREELANCE
  ETUDIANT
  PME
}

// ---------- UTILISATEUR ----------

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  motDePasseHash  String
  nomComplet      String
  telephone       String?
  entreprise      String?
  secteur         CategorieActivite @default(COMMERCANT)
  logoUrl         String?
  slugBoutique    String            @unique
  couleurBoutique String            @default("#FF6B35")
  estAdmin        Boolean           @default(false)

  plan         Plan      @default(GRATUIT)
  planExpireLe DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients       Client[]
  produits      Produit[]
  factures      Facture[]
  depenses      Depense[]
  rendezVous    RendezVous[]
  paiements     Paiement[]
  commandes     Commande[]
  cvs           CV[]
  flyers        Flyer[]
  notifications Notification[]

  @@index([slugBoutique])
}

// ---------- CLIENTS ----------

model Client {
  id        String   @id @default(cuid())
  userId    String
  nom       String
  telephone String?
  email     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  factures Facture[]

  @@index([userId])
}

// ---------- PRODUITS ----------

model Produit {
  id          String   @id @default(cuid())
  userId      String
  nom         String
  description String?  @db.Text
  prix        Decimal  @db.Decimal(12, 2)
  stock       Int      @default(0)
  seuilAlerte Int      @default(5)
  photoUrl    String?
  categorie   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  ligneFactures  LigneFacture[]
  ligneCommandes LigneCommande[]

  @@index([userId])
}

// ---------- FACTURATION ----------

model Facture {
  id        String        @id @default(cuid())
  userId    String
  clientId  String?
  numero    String        @unique
  statut    StatutFacture @default(IMPAYEE)
  total     Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now())

  user   User           @relation(fields: [userId], references: [id])
  client Client?        @relation(fields: [clientId], references: [id])
  lignes LigneFacture[]

  @@index([userId])
  @@index([clientId])
}

model LigneFacture {
  id           String  @id @default(cuid())
  factureId    String
  produitId    String?
  designation  String
  quantite     Int
  prixUnitaire Decimal @db.Decimal(12, 2)

  facture Facture  @relation(fields: [factureId], references: [id])
  produit Produit? @relation(fields: [produitId], references: [id])

  @@index([factureId])
  @@index([produitId])
}

// ---------- DEPENSES ----------

model Depense {
  id        String   @id @default(cuid())
  userId    String
  montant   Decimal  @db.Decimal(12, 2)
  categorie String
  note      String?
  date      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ---------- AGENDA ----------

model RendezVous {
  id                 String   @id @default(cuid())
  userId             String
  titre              String
  description        String?
  dateHeure          DateTime
  rappelMinutesAvant Int?     @default(60)
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ---------- PAIEMENT MANUEL (Orange Money / Mobile Money) ----------

model Paiement {
  id                   String         @id @default(cuid())
  userId               String
  planDemande          Plan
  montant              Decimal        @db.Decimal(12, 2)
  referenceTransaction String
  captureUrl           String
  statut               StatutPaiement @default(EN_ATTENTE)
  noteAdmin            String?
  validePar            String?
  createdAt            DateTime       @default(now())
  traiteLe             DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([statut])
}

// ---------- BOUTIQUE EN LIGNE ----------

model Commande {
  id              String         @id @default(cuid())
  userId          String
  clientNom       String
  clientTelephone String
  statut          StatutCommande @default(NOUVELLE)
  createdAt       DateTime       @default(now())

  user   User            @relation(fields: [userId], references: [id])
  lignes LigneCommande[]

  @@index([userId])
}

model LigneCommande {
  id           String  @id @default(cuid())
  commandeId   String
  produitId    String
  quantite     Int
  prixUnitaire Decimal @db.Decimal(12, 2)

  commande Commande @relation(fields: [commandeId], references: [id])
  produit  Produit  @relation(fields: [produitId], references: [id])

  @@index([commandeId])
  @@index([produitId])
}

// ---------- CV & FLYERS ----------

model CV {
  id          String   @id @default(cuid())
  userId      String
  titre       String   @default("Mon CV")
  contenuJson String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Flyer {
  id          String   @id @default(cuid())
  userId      String
  titre       String   @default("Mon flyer")
  templateId  String
  contenuJson String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ---------- NOTIFICATIONS ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  titre     String
  message   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
